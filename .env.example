APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8710
DATABASE_URL=sqlite:///./data/plankiller.db
TIMEZONE=Asia/Shanghai

# OpenAI / 本地 Ollama 二选一
# 使用 OpenAI：填写 OPENAI_API_KEY，保持 OPENAI_BASE_URL 默认
