OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=true
RAG_TOP_K=5

QQ_BOT_APP_ID=
QQ_BOT_SECRET=
QQ_BOT_TARGET_ID=
